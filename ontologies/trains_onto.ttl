@prefix : <http://example.org/trains-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Classi
:Train a owl:Class ; rdfs:label "Train"@en .
:Station a owl:Class ; rdfs:label "Station"@en .
:City a owl:Class ; rdfs:label "City"@en .
:Country a owl:Class ; rdfs:label "Country"@en .
:TrainType a owl:Class ; rdfs:label "Train Type"@en .

# Proprietà Oggetto
:departsFrom a owl:ObjectProperty ; rdfs:domain :Train ; rdfs:range :Station .
:arrivesAt a owl:ObjectProperty ; rdfs:domain :Train ; rdfs:range :Station .
:hasType a owl:ObjectProperty ; rdfs:domain :Train ; rdfs:range :TrainType .
:locatedIn a owl:ObjectProperty ; rdfs:domain :Station ; rdfs:range :City .
:cityInCountry a owl:ObjectProperty ; rdfs:domain :City ; rdfs:range :Country .
:passesThrough a owl:ObjectProperty ; rdfs:domain :Train ; rdfs:range :Station .

# Proprietà Datatype
:hasNumber a owl:DatatypeProperty ; rdfs:domain :Train ; rdfs:range xsd:string .
:departureTime a owl:DatatypeProperty ; rdfs:domain :Train ; rdfs:range xsd:time .
:arrivalTime a owl:DatatypeProperty ; rdfs:domain :Train ; rdfs:range xsd:time .
:duration a owl:DatatypeProperty ; rdfs:domain :Train ; rdfs:range xsd:integer .
:price a owl:DatatypeProperty ; rdfs:domain :Train ; rdfs:range xsd:decimal .
:hasName a owl:DatatypeProperty ; rdfs:domain :Station ; rdfs:range xsd:string .
:hasPopulation a owl:DatatypeProperty ; rdfs:domain :City ; rdfs:range xsd:integer .